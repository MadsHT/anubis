# Anubis RAG Engine - Environment Variables
# Copy this file to .env and update with your values

# Database Configuration
DB_USER=anubis_user
DB_PASSWORD=change_me_to_a_strong_password
DB_NAME=anubis_db

# Server Configuration (optional - most are set via config.yaml)
LOG_LEVEL=INFO
WORKERS=4

# Note: Ollama base URL is automatically set to http://ollama:11434
# when running via docker-compose. For different deployments, update
# the docker-compose.yml file directly.
